AUTH_SECRET=""

# SQLite database file (created automatically)
# Stored at prisma/db.sqlite — do not change unless you know what you're doing
DATABASE_URL="file:./db.sqlite"

# Optional OAuth (not needed for local dev — use "Dev Login" instead)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_DISCORD_ID=""
# AUTH_DISCORD_SECRET=""

# Admin page password (default for local dev: admin123)
ADMIN_PASSWORD="admin123"
