AUTH_SECRET=""

# Local SQLite (default). Prisma CLI uses this URL; runtime resolves paths in src/server/db.ts
DATABASE_URL="file:./db.sqlite"

# Turso (optional local dev)
# TURSO_DATABASE_URL="libsql://your-db-yourorg.aws-ap-northeast-1.turso.io"

# Platform API token from Turso dashboard (for npm run turso:db-token)
# TURSO_PLATFORM_TOKEN=""

# Database auth token (NOT the platform token). Run: npm run turso:db-token
# TURSO_API_KEY=""

# Admin page password (default for local dev: admin123)
ADMIN_PASSWORD="admin123"

# Secret for Vercel cron job auth (generate with: openssl rand -hex 32)
CRON_SECRET=""

# Cloudflare R2 (avatar uploads). Bucket needs public access enabled (r2.dev URL)
# and an API token scoped to Object Read & Write on the bucket.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="savingforbonding-avatars"
R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"
