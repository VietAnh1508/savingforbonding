generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
  POSTPONED
  CANCELLED
}

enum VoteOutcome {
  HOME_WIN
  DRAW
  AWAY_WIN
}

enum ChallengeStatus {
  OPEN
  ACCEPTED
  REJECTED
  CANCELLED
  ABANDONED
  REVIEW
  CONFLICT
  DONE
}

model Stage {
  id                  String        @id
  name                String
  startDate           DateTime
  endDate             DateTime
  sequenceOrder       Int
  seasonId            String
  isKnockout          Boolean       @default(false)
  starsAllocated      Int           @default(0)
  maxStarMultiplier   Int           @default(0)
  matches             Match[]
  penalty             StagePenalty?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * Singleton settings row (id fixed at 1) for game config that isn't stage-scoped.
 */
model GameSettings {
  id                        Int @id @default(1)
  championMaxStarMultiplier Int @default(4)
}

model StagePenalty {
  id            String @id @default(cuid())
  stageId       String @unique
  stage         Stage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  wrongPenalty  Int
  noVotePenalty Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id               String       @id @default(cuid())
  externalId       String?      @unique
  tournament       String       @default("FIFA World Cup")
  homeCountry      String
  awayCountry      String
  kickoffAt        DateTime
  status           MatchStatus  @default(SCHEDULED)
  homeScore        Int?
  awayScore        Int?
  homePenaltyScore Int?
  awayPenaltyScore Int?
  result           VoteOutcome?
  homeRatio        Float        @default(0)
  awayRatio        Float        @default(0)
  stageId          String?
  stage            Stage?       @relation(fields: [stageId], references: [id])
  votes            Vote[]
  challenges       Challenge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kickoffAt])
  @@index([status])
  @@index([stageId])
}

model Vote {
  id             String        @id @default(cuid())
  userId         String
  matchId        String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  match          Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  outcome        VoteOutcome
  isCorrect      Boolean?
  starMultiplier Int?
  points         Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
  @@index([userId])
}

model User {
  id                   String        @id @default(cuid())
  name                 String?
  email                String        @unique
  passwordHash         String?
  emailVerified        DateTime?
  image                String?
  totalPoints          Int           @default(0)
  weeklyPoints         Int           @default(0)
  mustChangePassword   Boolean       @default(false)
  createdAt            DateTime      @default(now())
  nameUpdatedAt        DateTime?
  termsAcceptedAt      DateTime?
  termsAcceptedVersion Int           @default(1)
  votes                Vote[]
  following            UserFollow[]  @relation("FollowerFollows")
  followers            UserFollow[]  @relation("FollowingFollows")
  championVote         ChampionVote?
  challengesSent       Challenge[]   @relation("ChallengeChallenger")
  challengesReceived   Challenge[]   @relation("ChallengeOpponent")
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("FollowerFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("FollowingFollows", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model ChampionCandidate {
  id           String         @id @default(cuid())
  fifaTeamId   String         @unique
  teamName     String
  countryCode  String
  eliminatedAt DateTime?
  votes        ChampionVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChampionVote {
  id             String             @id @default(cuid())
  userId         String             @unique
  candidateId    String?
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidate      ChampionCandidate? @relation(fields: [candidateId], references: [id])
  isCorrect      Boolean?
  starMultiplier Int?
  points         Int                @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateId])
}

model Challenge {
  id           String          @id @default(cuid())
  challengerId String
  opponentId   String
  matchId      String
  stakeBeers   Int
  condition    String
  status       ChallengeStatus @default(OPEN)

  challengerPickedWinnerId String?
  opponentPickedWinnerId   String?
  winnerId                 String?
  resolvedAt               DateTime?

  // Beer delta actually applied to each side on settlement (mirrors
  // Vote.points / ChampionVote.points) — an audit trail, not a source of
  // truth. User.totalPoints stays authoritative.
  challengerPoints Int?
  opponentPoints   Int?

  challenger User  @relation("ChallengeChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  opponent   User  @relation("ChallengeOpponent", fields: [opponentId], references: [id], onDelete: Cascade)
  match      Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId, status])
  @@index([opponentId, status])
  @@index([challengerId])
}
